@page "/addInvItem"

@inject IAddInvUseCase AddInvUseCase
@inject NavigationManager NavigationManager

<h3>Add Inventory Item</h3>

<br/>

<EditForm Model="inv" FormName="formInventory" OnValidSubmit="Add">
    <DataAnnotationsValidator></DataAnnotationsValidator>
   
    <div class="form-group">
        <label for="name">Item Name</label>
        <InputText id="name" @bind-Value="inv.InvName" class="form-control"></InputText>
        <ValidationMessage For="() => inv.InvName"></ValidationMessage>
    </div>

    <div class="form-group">
        <label for="quantity">Quantity</label>
        <InputNumber id="quantity" @bind-Value="inv.Quantity" class="form-control"></InputNumber>
        <ValidationMessage For="() => inv.Quantity"></ValidationMessage>
    </div>

    <div class="form-group">
        <label for="price">Price</label>
        <InputNumber id="price" @bind-Value="inv.Price" class="form-control"></InputNumber>
        <ValidationMessage For="() => inv.Price"></ValidationMessage>
    </div>

    <br/>

    <button type="submit" class="btn btn-success">Add</button>
    <a href="/InventoryList" class="btn btn-danger">Cancel</a>

</EditForm>

@code {
    [SupplyParameterFromForm]
    private Inventory inv { get; set; } = new Inventory();

    private async Task Add()
    {
        await AddInvUseCase.ExecuteAsync(inv);

        NavigationManager.NavigateTo("/InventoryList");
    }
}
