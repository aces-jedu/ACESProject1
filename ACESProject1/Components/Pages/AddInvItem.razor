@page "/addinventoryitem"

@inject IAddInvUseCase AddInvUseCase

<h3>Add Inventory Item</h3>

<br />
<br />

<EditForm Model="inventory" FormName="formInventory" OnValidSubmit="Add">

    <div class="form-group">
        <label for="name"> Inventory Name</label>
        <InputText id="name" @bind-Value="inventory.InvName" class="form-control"></InputText>
    </div>

    <div class="form-group">
        <label for="quantity"> Quantity </label>
        <InputNumber id="quantity" @bind-Value="inventory.Quantity" class="form-control"></InputNumber>
    </div>

    <div class="form-group">
        <label for="price"> Price </label>
        <InputNumber id="price" @bind-Value="inventory.Price" class="form-control"></InputNumber>
    </div>

    <br />

    <button type="submit" class="btn btn-success"> Add </button>

</EditForm>

@code {

    [SupplyParameterFromForm]
    private Inventory inventory { get; set; } = new Inventory();

    private async Task Add()
    {
        await AddInvUseCase.ExecuteAsync(inventory);
    }
}
