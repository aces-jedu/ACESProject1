@page "/InventoryList"

@inject IViewInvbyNameUseCase ViewInvbyNameUseCase

<PageTitle>Inventory List</PageTitle>

<br />
<br />

<ul>
@if (inventories is not null && inventories.Count > 0)

    foreach(var inv in inventories)
    {
        <li>
            @inv.InvName
        </li>
    }
</ul>

<br />
<br />
<a href="/addinventoryitem" class="btn btn-primary"> Add Inventory Item </a>

@code {
    private List<Inventory>? inventories;

    protected override async Task OnInitializedAsync()
    {
        inventories = (await ViewInvbyNameUseCase.ExecuteAsync()).ToList();
    }
}